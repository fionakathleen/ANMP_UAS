<?xml version="1.0" encoding="utf-8"?>

<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.habittracker.ui.dashboard.DashboardFragment"
        android:label="Dashboard">

        <action
            android:id="@+id/action_dashboardFragment_to_createHabitFragment"
            app:destination="@id/createHabitFragment"/>

        <action
            android:id="@+id/action_dashboardFragment_to_editHabitFragment"
            app:destination="@id/editHabitFragment"/>

    </fragment>

    <fragment
        android:id="@+id/createHabitFragment"
        android:name="com.example.habittracker.ui.createhabit.CreateHabitFragment"
        android:label="Create Habit"/>

    <argument
        android:name="habitId"
        app:argType="integer"/>

    <fragment
        android:id="@+id/editHabitFragment"
        android:name="com.example.habittracker.ui.edithabit.EditHabitFragment"
        android:label="Edit Habit">

        <argument
            android:name="habitId"
            app:argType="integer"/>

    </fragment>

</navigation>